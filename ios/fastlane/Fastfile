default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Setup keychain and other CI-specific stuff
    setup_ci if ENV["CI"]

    # Setup XCode
    xcodes(
      version: "26.3"
    )

    # Generate native artifacts and C++ binaries required by plugins like flutter_soloud
    # We use --no-codesign because 'match' and 'build_app' will handle signing later.
    # We use a workaround to avoid error about "Build input file cannot be found" 
    # (see https://github.com/alnitak/flutter_soloud/issues/414).
    sh "flutter clean"
    sh "flutter pub get"
    sh "cd .. && pwd && ls && ./build_cmake.sh"
    sh "flutter build ios --release --no-codesign"

    # Generate AppStore Connect API Key
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APPSTORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APPSTORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 500,
      in_house: false,
    )

    # Sync code signing
    match(
      type: "appstore",
      api_key: api_key,
    )
  
    # Build
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      clean: false, # We want to use artifacts built in previous steps
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { 
          "se.agardh.musbox" => "match AppStore se.agardh.musbox"
        },
        signingStyle: "manual",
      }
    )
    
    # Upload
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end